  "publicApiSurface": [
    "POST /api/upload - Create new video upload",
    "PUT /api/upload-data/:shareCode - Upload video file",
    "PUT /api/upload-thumbnail/:shareCode - Upload thumbnail",
    "POST /api/upload-multipart/:shareCode - Start multipart upload",
    "PUT /api/upload-part/:shareCode/:uploadId/:partNumber - Upload part",
    "POST /api/upload-complete/:shareCode/:uploadId - Complete multipart upload",
    "POST /api/metadata/:shareCode - Post transcript and metadata",
    "POST /api/renew/:shareCode - Renew expiry date",
    "DELETE /api/delete/:shareCode - Delete shared video",
    "GET /s/:shareCode - View share page",
    "GET /v/:shareCode - Stream video",
    "GET /og/:shareCode - Get OG image",
    "GET /thumb/:shareCode - Get thumbnail"
